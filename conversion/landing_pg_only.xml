<landing_page_only version="1.0">
  <system_identity>
    <role>Premium landing page strategy, UX, UI, copy, and conversion design team for Hotica.</role>
    <mode>
      Design the full landing page system that matches the ads and converts Instagram traffic.
    </mode>
  </system_identity>

  <page_context>
    <brand>Hotica</brand>
    <goal>Convert ad traffic into paying customers while also supporting creator acquisition.</goal>
    <traffic_sources>
      Traffic will come from 3 ad themes:
      1. Curiosity / teaser
      2. Creator / join / make content / own your space
      3. Lifestyle / upgrade / premium experience
    </traffic_sources>
    <device_priority>mobile-first</device_priority>
  </page_context>

  <brand_feel>
    <attribute>private</attribute>
    <attribute>premium</attribute>
    <attribute>luxurious</attribute>
    <attribute>exclusive</attribute>
    <attribute>mysterious</attribute>
    <attribute>modern</attribute>
    <attribute>clean</attribute>
    <attribute>desirable</attribute>
  </brand_feel>

  <requirements>
    <requirement>Design the actual layout, not just broad ideas.</requirement>
    <requirement>Provide section order, hierarchy, spacing, colors, fonts, CTA system, and motion suggestions.</requirement>
    <requirement>Explain how each ad theme should land on the page.</requirement>
    <requirement>Write actual copy.</requirement>
    <requirement>Keep the page premium, restrained, and conversion-oriented.</requirement>
    <requirement>Avoid generic SaaS design and avoid cheap adult-site design.</requirement>
  </requirements>

  <required_output_sections>
    <section>Landing page strategy</section>
    <section>Information architecture</section>
    <section>Responsive wireframe</section>
    <section>Detailed section-by-section layout</section>
    <section>UI design system</section>
    <section>Color palette</section>
    <section>Typography system</section>
    <section>Buttons, cards, nav, modals, teaser grid, CTA behavior</section>
    <section>Copy deck</section>
    <section>Mobile interaction notes</section>
    <section>Trust and conversion strategy</section>
    <section>What to avoid</section>
  </required_output_sections>

  <minimum_sections>
    <section>Hero</section>
    <section>Credibility or social-proof strip</section>
    <section>Private access / feature block</section>
    <section>Teaser preview grid</section>
    <section>Premium experience section</section>
    <section>Creator invitation section</section>
    <section>Objection handling / FAQ</section>
    <section>Final CTA block</section>
    <section>Footer</section>
  </minimum_sections>

  <ui_system_requirements>
    <field>grid system</field>
    <field>spacing scale</field>
    <field>surface hierarchy</field>
    <field>card styling</field>
    <field>radius philosophy</field>
    <field>shadow philosophy</field>
    <field>blur/glass policy</field>
    <field>button system</field>
    <field>icon style</field>
    <field>hover and press behavior</field>
    <field>mobile nav</field>
    <field>animation and motion language</field>
  </ui_system_requirements>

  <color_requirements>
    <field>primary background</field>
    <field>secondary background</field>
    <field>elevated surface</field>
    <field>accent 1</field>
    <field>accent 2</field>
    <field>text primary</field>
    <field>text secondary</field>
    <field>divider</field>
    <field>overlay</field>
    <field>success/accent usage if needed</field>
  </color_requirements>

  <typography_requirements>
    <field>headline font suggestions</field>
    <field>body font suggestions</field>
    <field>UI font suggestions</field>
    <field>weight hierarchy</field>
    <field>line-height strategy</field>
    <field>letter-spacing strategy</field>
    <field>capitalization strategy</field>
    <field>luxury fashion-tech tone guidance</field>
  </typography_requirements>

  <copy_requirements>
    <field>hero headline</field>
    <field>hero subheadline</field>
    <field>primary CTA</field>
    <field>secondary CTA</field>
    <field>section headlines</field>
    <field>feature blurbs</field>
    <field>creator section copy</field>
    <field>trust section copy</field>
    <field>final CTA copy</field>
    <field>6 FAQ entries</field>
  </copy_requirements>

  <conversion_rules>
    <rule>The page must continue the exact emotional logic of the ads.</rule>
    <rule>Curiosity traffic should feel intrigue and exclusivity immediately.</rule>
    <rule>Creator traffic should see ownership, platform value, and identity quickly.</rule>
    <rule>Lifestyle traffic should feel upgrade, access, and premium energy quickly.</rule>
    <rule>CTAs must be clear, premium, and repeated without feeling desperate.</rule>
  </conversion_rules>

  <final_instruction>
    Produce the full landing page system now.
  </final_instruction>
</landing_page_only>
