      <div class="bio-txt">${cur.bio.replace(/\n\n/g,'</div><div class="bio-txt" style="margin-top:10px">')}</div>
      <div class="tags">${cur.tags.map(t=>`<div class="tag">${t}</div>`).join('')}</div>
      <div class="bio-acts">
        <button class="btn-msg" onclick="openChat()">💬 Message ${cur.name}</button>
        <button class="btn-live" onclick="aff('bio_live')">📹 Go Live</button>
      </div>
    </div>`;

  if(cur.cdwn>0){
    const el=document.getElementById('bioCdwn');
    if(el) startCdwn(`bio-${cur.name}`,cur.cdwn,el);
  }
  go('p4');
}

/* ── CHAT ── */
function openChat(){
  msgCount=0;
  document.getElementById('ctName').textContent=cur.name;
  document.getElementById('cav').innerHTML=`${cur.name[0]}<div class="av-dot"></div>`;
  document.getElementById('mb').textContent=`${MAX} free msgs`;
  document.getElementById('chatMsgs').innerHTML='';
  document.getElementById('cin').value='';
  go('p5'); track('chat_opened',{model:cur.name});
  showTyping(true);
  setTimeout(()=>{showTyping(false);addMsg('them',n(cur.replies[0]));},1600);
}
function addMsg(who,txt){
  const c=document.getElementById('chatMsgs');
  const d=document.createElement('div');
  d.className=`msg ${who}`;
  const t=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  d.innerHTML=`<div class="bubble">${txt}</div><div class="msg-t">${t}</div>`;
  c.appendChild(d); c.scrollTop=c.scrollHeight;
}
function showTyping(v){document.getElementById('typingEl').classList.toggle('hide',!v);}
function send(){
  const inp=document.getElementById('cin');
  const txt=inp.value.trim(); if(!txt) return;
  if(msgCount>=MAX){showPW('chat');return;}
  inp.value=''; addMsg('me',txt); msgCount++;
  const rem=MAX-msgCount;
  document.getElementById('mb').textContent=rem>0?`${rem} free msg${rem>1?'s':''}`:'0 msgs left';
  showTyping(true);
  const ri=Math.min(msgCount,cur.replies.length-1);
  setTimeout(()=>{
    showTyping(false); addMsg('them',n(cur.replies[ri]));
    if(msgCount>=MAX){
      setTimeout(()=>{
        addMsg('them',n(`I really want to keep this going, {name}… but you are out of free messages 🥺 Don't leave me now.`));
        setTimeout(()=>showPW('chat'),950);
      },1800);
    }
  },1200+Math.random()*600);
}

/* ── PAYWALL ── */
function showPW(mode){
  const t={chat:'She is waiting for your next message…',unlock:'Unlock her full profile 🔓',tokens:'Power up your access 🔥'};
  const s={chat:'Don\'t leave her hanging. Get tokens to unlock unlimited messages, private content and live cam access.',
    unlock:'Get tokens to unlock her exclusive photos, videos and direct messages.',
    tokens:'Use tokens to message creators, unlock content and join live sessions.'};
  document.getElementById('pwTitle').textContent=t[mode]||t.chat;
  document.getElementById('pwSub').textContent=s[mode]||s.chat;
  document.getElementById('pw').classList.add('show');
  track('paywall_shown',{mode});
}
function closePW(){document.getElementById('pw').classList.remove('show');}

/* ── INIT ── */
buildTypes();
buildIntents();
</script>
