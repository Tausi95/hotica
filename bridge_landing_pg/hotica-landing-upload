/* ── COUNTDOWN ── */
function fmtTime(s){
  const m=Math.floor(s/60),sec=s%60;
  return `${m}:${sec.toString().padStart(2,'0')}`;
}
function startCdwn(id,secs,el){
  if(cdwnIntervals[id]) clearInterval(cdwnIntervals[id]);
  let t=secs;
  el.textContent=fmtTime(t);
  cdwnIntervals[id]=setInterval(()=>{
    t--; if(t<=0){clearInterval(cdwnIntervals[id]);el.textContent='LIVE NOW';return;}
    el.textContent=fmtTime(t);
  },1000);
}

