<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;background:#1a1220;color:#fff;font-family:'Segoe UI',system-ui,sans-serif;overflow:hidden;}
:root{
  --navy:#1a1220;--card:#251c30;--card2:#2e2340;--border:#3d3055;
  --pink:#f080a0;--pink2:#e0506e;--glow:rgba(240,128,160,.32);
  --muted:#b0a0c0;--dim:#706080;
}
.bg{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
.blob{position:absolute;border-radius:50%;filter:blur(110px);opacity:.15;}
.b1{width:550px;height:550px;background:var(--pink);top:-200px;left:-150px;animation:drift 11s ease-in-out infinite alternate;}
.b2{width:420px;height:420px;background:#8855cc;bottom:-130px;right:-100px;animation:drift 14s ease-in-out infinite alternate-reverse;}
.b3{width:300px;height:300px;background:var(--pink2);top:45%;left:48%;animation:drift 16s ease-in-out infinite alternate;}
@keyframes drift{from{transform:translate(0,0)scale(1);}to{transform:translate(24px,18px)scale(1.1);}}

.screen{position:fixed;inset:0;z-index:1;display:flex;flex-direction:column;overflow:hidden;
  transition:opacity .4s ease,transform .4s ease;}
.screen.off{opacity:0;pointer-events:none;transform:translateY(22px);}

.topbar{display:flex;align-items:center;justify-content:space-between;
  padding:13px 18px;border-bottom:1px solid rgba(255,255,255,.06);
  background:rgba(26,18,32,.9);backdrop-filter:blur(18px);flex-shrink:0;}
.logo{font-size:1.55rem;font-weight:900;letter-spacing:-1px;line-height:1;display:flex;align-items:center;}
.logo .o{color:var(--pink);font-size:1.3em;line-height:.8;margin:0 -1px;}
.pill{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.07);padding:5px 11px;border-radius:20px;}
.dot{width:7px;height:7px;border-radius:50%;background:#4ade80;box-shadow:0 0 6px #4ade80;animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.3;}}
.pill span{font-size:.73rem;color:var(--muted);}
.prog{height:3px;background:rgba(255,255,255,.05);flex-shrink:0;}
.prog-bar{height:100%;background:linear-gradient(90deg,var(--pink),var(--pink2));transition:width .5s ease;}

.btn{border:none;cursor:pointer;font-weight:800;transition:transform .2s,box-shadow .2s;}
.btn-main{background:linear-gradient(135deg,var(--pink),var(--pink2));color:#fff;
  padding:15px 32px;border-radius:50px;font-size:1rem;letter-spacing:.3px;
  box-shadow:0 10px 28px var(--glow);}
.btn-main:hover{transform:translateY(-2px);box-shadow:0 16px 36px var(--glow);}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--muted);
  padding:13px 32px;border-radius:50px;font-size:.9rem;}
.btn-ghost:hover{border-color:var(--pink);color:var(--pink);}
.btn-tok{background:linear-gradient(135deg,var(--pink),var(--pink2));color:#fff;
  font-size:.73rem;font-weight:800;padding:6px 13px;border-radius:18px;
  box-shadow:0 4px 12px var(--glow);}
.back{background:none;border:none;color:var(--pink);font-size:1.2rem;cursor:pointer;padding:4px 8px;}

/* ── P1 AGE GATE ── */
#p1 .body{flex:1;display:flex;flex-direction:column;align-items:center;
  justify-content:center;text-align:center;padding:24px;overflow-y:auto;}
.reels{display:flex;gap:9px;justify-content:center;margin-bottom:28px;}
.reel{width:84px;height:136px;border-radius:15px;background:var(--card);
  border:1px solid var(--border);position:relative;overflow:hidden;flex-shrink:0;}
.reel:nth-child(2),.reel:nth-child(4){transform:translateY(-13px);}
.reel img{width:100%;height:100%;object-fit:cover;display:block;}
.reel-ph{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:5px;color:var(--border);font-size:.55rem;}
.reel-ph span{font-size:1.5rem;opacity:.25;}
.reel-veil{position:absolute;inset:0;backdrop-filter:blur(6px);
  background:rgba(26,18,32,.35);display:flex;align-items:center;justify-content:center;font-size:1.4rem;}
.badge{display:inline-block;background:rgba(240,128,160,.1);border:1px solid rgba(240,128,160,.28);
  color:var(--pink);font-size:.66rem;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;
  padding:5px 13px;border-radius:20px;margin-bottom:15px;}
.gate-h{font-size:clamp(1.8rem,5.5vw,2.7rem);font-weight:900;line-height:1.1;margin-bottom:10px;}
.gate-h em{font-style:normal;color:var(--pink);}
.gate-sub{font-size:.87rem;color:var(--muted);line-height:1.7;max-width:320px;margin-bottom:26px;}
.age-btns{display:flex;flex-direction:column;gap:10px;width:100%;max-width:310px;margin:0 auto 16px;}
.legal{font-size:.66rem;color:var(--dim);max-width:320px;line-height:1.7;}
.legal a{color:var(--muted);}

/* ── P2 TYPE PICKER ── */
#p2 .body{flex:1;overflow-y:auto;padding:20px 16px 30px;display:flex;flex-direction:column;align-items:center;}
.step-lbl{font-size:.65rem;color:var(--dim);letter-spacing:2px;text-transform:uppercase;margin-bottom:7px;}
.p2-h{font-size:clamp(1.35rem,4vw,2rem);font-weight:900;text-align:center;line-height:1.2;margin-bottom:5px;}
.p2-sub{font-size:.83rem;color:var(--muted);text-align:center;margin-bottom:20px;}
.type-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;max-width:470px;margin-bottom:20px;}
.tcard{background:var(--card);border:2px solid var(--border);border-radius:15px;
  overflow:hidden;cursor:pointer;transition:border-color .25s,transform .2s;position:relative;}
.tcard:hover{border-color:rgba(240,128,160,.5);transform:scale(1.02);}
.tcard.sel{border-color:var(--pink);background:rgba(240,128,160,.07);}
.tcard-img{width:100%;aspect-ratio:3/4;object-fit:cover;display:block;}
.tcard-ph{width:100%;aspect-ratio:3/4;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:5px;color:var(--border);font-size:.55rem;}
.tcard-ph span{font-size:1.8rem;opacity:.2;}
.tcard-foot{padding:10px 12px;display:flex;justify-content:space-between;align-items:center;}
.tcard-foot strong{font-size:.86rem;}
.tcard-foot em{font-size:.7rem;color:var(--dim);font-style:normal;}
.chk{position:absolute;top:9px;right:9px;width:22px;height:22px;border-radius:50%;
  background:var(--pink);display:none;align-items:center;justify-content:center;
  font-size:.68rem;font-weight:900;box-shadow:0 4px 10px var(--glow);}
.tcard.sel .chk{display:flex;}
.btn-next{width:100%;max-width:470px;font-size:.97rem;opacity:.3;pointer-events:none;}
.btn-next.on{opacity:1;pointer-events:all;}

/* ── P2B INTENT PICKER ── */
#p2b .body{flex:1;overflow-y:auto;padding:20px 16px 30px;display:flex;flex-direction:column;align-items:center;}
.intent-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;max-width:470px;margin-bottom:20px;}
.icard{background:var(--card);border:2px solid var(--border);border-radius:15px;
  padding:22px 14px;cursor:pointer;text-align:center;
  transition:border-color .25s,transform .2s,background .2s;position:relative;}
.icard:hover{border-color:rgba(240,128,160,.5);transform:scale(1.02);}
.icard.sel{border-color:var(--pink);background:rgba(240,128,160,.08);}
.icard-ico{font-size:2.2rem;margin-bottom:10px;}
.icard-label{font-size:.95rem;font-weight:800;color:#fff;margin-bottom:4px;}
.icard-sub{font-size:.72rem;color:var(--dim);}
.ichk{position:absolute;top:9px;right:9px;width:22px;height:22px;border-radius:50%;
  background:var(--pink);display:none;align-items:center;justify-content:center;
  font-size:.68rem;font-weight:900;}
.icard.sel .ichk{display:flex;}

/* ── P2C NICKNAME ── */
#p2c .body{flex:1;display:flex;flex-direction:column;align-items:center;
  justify-content:center;text-align:center;padding:28px 22px;}
.nick-ico{font-size:3rem;margin-bottom:16px;}
.nick-h{font-size:clamp(1.4rem,4vw,2rem);font-weight:900;margin-bottom:8px;}
.nick-sub{font-size:.86rem;color:var(--muted);margin-bottom:28px;line-height:1.65;max-width:300px;}
.nick-input{width:100%;max-width:340px;background:var(--card);border:2px solid var(--border);
  border-radius:50px;color:#fff;font-size:1rem;padding:14px 22px;outline:none;
  text-align:center;margin-bottom:14px;transition:border-color .2s;}
.nick-input:focus{border-color:var(--pink);}
.nick-input::placeholder{color:var(--dim);}
.nick-skip{font-size:.75rem;color:var(--dim);cursor:pointer;margin-top:6px;
  background:none;border:none;text-decoration:underline;}

/* ── P3 BROWSE ── */
.bar-r{display:flex;gap:8px;align-items:center;}
.filters{display:flex;gap:7px;padding:10px 13px;overflow-x:auto;flex-shrink:0;scrollbar-width:none;}
.filters::-webkit-scrollbar{display:none;}
.ftab{flex-shrink:0;padding:5px 13px;border-radius:18px;border:1px solid var(--border);
  font-size:.74rem;color:var(--dim);cursor:pointer;background:var(--card);transition:all .2s;}
.ftab.act{background:linear-gradient(135deg,var(--pink),var(--pink2));border-color:transparent;color:#fff;font-weight:700;}
.mgrid{flex:1;overflow-y:auto;display:grid;grid-template-columns:1fr 1fr;gap:2px;padding:2px;}
.mgrid::-webkit-scrollbar{width:3px;}
.mgrid::-webkit-scrollbar-thumb{background:var(--border);}
.mcard{position:relative;aspect-ratio:2/3;background:var(--card);cursor:pointer;overflow:hidden;transition:transform .2s;}
.mcard:hover{transform:scale(1.02);z-index:2;}
.mcard img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.mcard-ph{position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:5px;color:var(--border);font-size:.55rem;}
.mcard-ph span{font-size:2rem;opacity:.2;}
.card-over{position:absolute;bottom:0;left:0;right:0;
  background:linear-gradient(transparent,rgba(26,18,32,.94));padding:24px 10px 10px;}
.card-name{font-size:.9rem;font-weight:700;}
.card-meta{display:flex;align-items:center;gap:5px;margin-top:3px;}
.live-tag{background:var(--pink2);color:#fff;font-size:.54rem;font-weight:800;padding:2px 6px;border-radius:7px;letter-spacing:.5px;}
.card-type{font-size:.68rem;color:#d0c0e0;}
.new-tag{position:absolute;top:8px;left:8px;background:var(--pink);color:#fff;font-size:.54rem;font-weight:800;padding:2px 7px;border-radius:7px;}
.hot-tag{position:absolute;top:8px;right:8px;font-size:.82rem;}
.gdot{width:6px;height:6px;border-radius:50%;background:#4ade80;flex-shrink:0;}
.countdown-tag{position:absolute;bottom:42px;right:8px;background:rgba(26,18,32,.85);
  border:1px solid var(--pink);color:var(--pink);font-size:.56rem;font-weight:800;
  padding:3px 7px;border-radius:8px;letter-spacing:.3px;}

/* ── P4 BIO ── */
.ver{background:rgba(240,128,160,.09);border:1px solid rgba(240,128,160,.28);
  color:var(--pink);font-size:.63rem;font-weight:700;padding:4px 9px;border-radius:11px;}
.bio-body{flex:1;overflow-y:auto;}
.bio-body::-webkit-scrollbar{width:3px;}
.bio-body::-webkit-scrollbar-thumb{background:var(--border);}
.med-row{display:flex;gap:2px;padding:2px;}
.med{flex:1;aspect-ratio:3/4;background:var(--card);border:1px solid var(--border);
  cursor:pointer;position:relative;overflow:hidden;}
.med img{width:100%;height:100%;object-fit:cover;display:block;}
.med-ph{width:100%;height:100%;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:4px;color:var(--border);font-size:.52rem;}
.med-ph span{font-size:1.6rem;opacity:.2;}
.med.vid::after{content:'▶';position:absolute;inset:0;display:flex;align-items:center;
  justify-content:center;font-size:1.3rem;color:rgba(255,255,255,.85);background:rgba(26,18,32,.25);}
.med.lk{opacity:.45;}
.med.lk::after{content:'🔒';position:absolute;inset:0;display:flex;align-items:center;
  justify-content:center;font-size:1rem;background:rgba(26,18,32,.4);}
.bio-info{padding:14px 16px;}
.bio-name{font-size:1.4rem;font-weight:900;margin-bottom:2px;}
.bio-loc{font-size:.78rem;color:var(--dim);margin-bottom:11px;}
.stats{display:flex;border:1px solid var(--border);border-radius:11px;overflow:hidden;margin-bottom:12px;background:var(--card);}
.stat{flex:1;text-align:center;padding:10px 5px;border-right:1px solid var(--border);}
.stat:last-child{border-right:none;}
.sv{font-size:.92rem;font-weight:800;}
.sl{font-size:.56rem;color:var(--dim);text-transform:uppercase;letter-spacing:.5px;margin-top:2px;}
.bio-quote{font-size:.92rem;color:#fff;font-style:italic;line-height:1.6;
  border-left:3px solid var(--pink);padding-left:12px;margin-bottom:12px;}
.bio-txt{font-size:.84rem;color:var(--muted);line-height:1.75;margin-bottom:12px;}
.tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:17px;}
.tag{background:var(--card);border:1px solid var(--border);color:var(--dim);font-size:.68rem;padding:4px 10px;border-radius:18px;}
.bio-acts{display:flex;gap:9px;padding:0 0 18px;}
.btn-msg{flex:1;padding:13px;border-radius:50px;border:none;
  background:linear-gradient(135deg,var(--pink),var(--pink2));color:#fff;
  font-size:.9rem;font-weight:800;cursor:pointer;box-shadow:0 8px 20px var(--glow);transition:transform .2s;}
.btn-msg:hover{transform:translateY(-2px);}
.btn-live{flex:1;padding:13px;border-radius:50px;border:2px solid var(--pink);
  background:transparent;color:var(--pink);font-size:.9rem;font-weight:800;cursor:pointer;}
.btn-live:hover{background:rgba(240,128,160,.08);}

/* bio countdown banner */
.bio-cdwn{display:flex;align-items:center;gap:10px;background:rgba(240,128,160,.08);
  border:1px solid rgba(240,128,160,.25);border-radius:10px;
  padding:10px 14px;margin-bottom:14px;}
.bio-cdwn-ico{font-size:1.2rem;}
.bio-cdwn-txt{flex:1;font-size:.78rem;color:var(--muted);}
.bio-cdwn-time{font-size:.95rem;font-weight:900;color:var(--pink);}

/* ── P5 CHAT ── */
.chat-top{display:flex;align-items:center;gap:10px;padding:10px 14px;
  border-bottom:1px solid rgba(255,255,255,.06);flex-shrink:0;
  background:rgba(26,18,32,.9);backdrop-filter:blur(14px);}
.cav{width:34px;height:34px;border-radius:50%;background:var(--card);
  border:2px solid var(--pink);display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:.9rem;flex-shrink:0;position:relative;}
.av-dot{position:absolute;bottom:0;right:0;width:8px;height:8px;
  border-radius:50%;background:#4ade80;border:2px solid var(--navy);}
.ct-name{font-size:.88rem;font-weight:700;}
.ct-st{font-size:.68rem;color:#4ade80;}
.mb{font-size:.66rem;color:var(--pink);font-weight:700;white-space:nowrap;}
.cam-sm{background:linear-gradient(135deg,var(--pink),var(--pink2));border:none;
  color:#fff;font-size:.64rem;font-weight:700;padding:6px 10px;border-radius:11px;cursor:pointer;}
.chat-msgs{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:9px;}
.chat-msgs::-webkit-scrollbar{width:3px;}
.chat-msgs::-webkit-scrollbar-thumb{background:var(--border);}
.msg{max-width:78%;display:flex;flex-direction:column;gap:3px;}
.msg.them{align-self:flex-start;}
.msg.me{align-self:flex-end;}
.bubble{padding:10px 14px;border-radius:17px;font-size:.85rem;line-height:1.5;}
.them .bubble{background:var(--card);color:#ddd;border-bottom-left-radius:4px;}
.me .bubble{background:linear-gradient(135deg,var(--pink),var(--pink2));color:#fff;border-bottom-right-radius:4px;}
.msg-t{font-size:.58rem;color:var(--dim);}
.me .msg-t{text-align:right;}
.typing{display:flex;align-items:center;gap:4px;padding:9px 14px;}
.typing span{width:7px;height:7px;border-radius:50%;background:var(--border);animation:tb .9s ease-in-out infinite;}
.typing span:nth-child(2){animation-delay:.15s;}
.typing span:nth-child(3){animation-delay:.3s;}
@keyframes tb{0%,80%,100%{transform:translateY(0);}40%{transform:translateY(-6px);background:var(--pink);}}
.typing.hide{display:none;}
.chat-in{display:flex;gap:8px;padding:10px 12px;border-top:1px solid rgba(255,255,255,.06);
  flex-shrink:0;background:rgba(26,18,32,.7);}
.cinput{flex:1;background:var(--card);border:1px solid var(--border);border-radius:22px;
  color:#fff;font-size:.85rem;padding:10px 15px;outline:none;transition:border-color .2s;}
.cinput:focus{border-color:rgba(240,128,160,.45);}
.cinput::placeholder{color:var(--dim);}
.send{width:38px;height:38px;border-radius:50%;border:none;flex-shrink:0;
  background:linear-gradient(135deg,var(--pink),var(--pink2));color:#fff;
  font-size:.88rem;cursor:pointer;display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 12px var(--glow);transition:transform .2s;}
.send:hover{transform:scale(1.1);}

/* ── TOAST ── */
#toast{position:fixed;top:70px;left:50%;transform:translateX(-50%) translateY(-20px);
  z-index:998;background:var(--card2);border:1px solid var(--border);
  border-radius:14px;padding:11px 16px;display:flex;align-items:center;gap:10px;
  font-size:.8rem;color:#fff;white-space:nowrap;
  opacity:0;pointer-events:none;transition:opacity .35s,transform .35s;
  box-shadow:0 8px 24px rgba(0,0,0,.4);}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.toast-av{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--pink),var(--pink2));
  display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.8rem;flex-shrink:0;}
.toast-txt strong{color:var(--pink);}

/* ── PAYWALL ── */
#pw{position:fixed;inset:0;z-index:999;display:flex;align-items:flex-end;
  background:rgba(10,6,16,.72);backdrop-filter:blur(10px);
  opacity:0;pointer-events:none;transition:opacity .35s;}
#pw.show{opacity:1;pointer-events:all;}
.pw-sheet{width:100%;background:#211830;border-radius:22px 22px 0 0;
  padding:20px 20px 32px;border-top:1px solid var(--border);
  transform:translateY(100%);transition:transform .42s cubic-bezier(.22,1,.36,1);}
#pw.show .pw-sheet{transform:translateY(0);}
.pw-h2{width:30px;height:4px;background:var(--border);border-radius:4px;margin:0 auto 15px;}
.pw-ico{font-size:2rem;text-align:center;margin-bottom:6px;}
.pw-title{font-size:1.12rem;font-weight:900;text-align:center;margin-bottom:5px;}
.pw-sub{font-size:.78rem;color:var(--muted);text-align:center;line-height:1.65;margin-bottom:17px;}
.pw-opts{display:flex;flex-direction:column;gap:9px;margin-bottom:13px;}
.pw-opt{display:flex;align-items:center;justify-content:space-between;
  padding:13px 14px;border-radius:13px;border:1px solid var(--border);
  background:var(--card);cursor:pointer;transition:border-color .2s;}
.pw-opt:hover,.pw-opt.best{border-color:rgba(240,128,160,.38);}
.pw-opt-l strong{display:block;font-size:.88rem;margin-bottom:2px;}
.pw-opt-l span{font-size:.7rem;color:var(--dim);}
.pw-opt-r{font-size:.9rem;font-weight:800;color:var(--pink);}
.best-pill{background:var(--pink);color:#fff;font-size:.5rem;font-weight:800;
  padding:2px 6px;border-radius:7px;margin-left:5px;vertical-align:middle;}
.pw-div{display:flex;align-items:center;gap:8px;margin:7px 0;}
.pw-div::before,.pw-div::after{content:'';flex:1;height:1px;background:var(--border);}
.pw-div span{font-size:.68rem;color:var(--dim);}
.btn-hot{width:100%;padding:14px;border-radius:50px;border:none;
  background:linear-gradient(135deg,var(--pink),var(--pink2));color:#fff;
  font-size:.9rem;font-weight:800;cursor:pointer;box-shadow:0 10px 24px var(--glow);transition:transform .2s;}
.btn-hot:hover{transform:translateY(-2px);}
.pw-note{text-align:center;font-size:.64rem;color:var(--dim);margin-top:8px;}

.exit-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px;}
</style>
</head>
<body>

<div class="bg">
  <div class="blob b1"></div><div class="blob b2"></div><div class="blob b3"></div>
</div>

<!-- TOAST -->
<div id="toast">
  <div class="toast-av" id="toastAv">A</div>
  <div class="toast-txt" id="toastTxt"><strong>Aria</strong> just viewed your profile 👀</div>
